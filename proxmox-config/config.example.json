{
    "proxmox": {
        "host": "your-proxmox-host-ip",
        "port": 8006,
        "verify_ssl": true,
        "ca_cert_path": null,
        "service": "PVE"
    },
    "auth": {
        "user": "mcp@pve",
        "token_name": "cursor",
        "token_value": "${PROXMOX_TOKEN_VALUE}"
    },
    "logging": {
        "level": "INFO",
        "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        "file": "logs/proxmox_mcp.log"
    }
}
